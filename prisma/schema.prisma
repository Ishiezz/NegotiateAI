generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Deal {
  id           String   @id @default(uuid())
  material     String
  quantity     String
  targetPrice  String
  deliveryDate String
  status       String   @default("NEGOTIATING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}